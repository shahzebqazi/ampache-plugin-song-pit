# Required: hex or long random string for JWT signing
SONGPIT_JWT_SECRET=change-me-to-a-long-random-string

# Required: API key for POST /v1/shares (maintainer)
SONGPIT_API_KEY=change-me-maintainer-key

# Where staged uploads are written (must be writable by the API process)
SONGPIT_STAGING_ROOT=/var/lib/songpit/staging

# Public URL of the upload SPA (used in share links)
SONGPIT_SPA_PUBLIC_URL=https://songpit.example.com/app
